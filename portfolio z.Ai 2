      *{margin:0;padding:0;box-sizing:border-box}
      ::selection{background:rgba(212,168,67,.3);color:#fff}
      ::-webkit-scrollbar{width:6px}
      ::-webkit-scrollbar-track{background:transparent}
      .dark ::-webkit-scrollbar-track{background:#050508}
      ::-webkit-scrollbar-thumb{background:rgba(212,168,67,.4);border-radius:3px}
      html{scroll-behavior:smooth}
      body{font-family:'Inter',sans-serif;overflow-x:hidden;cursor:none;transition:background-color 0.5s, color 0.5s}
      .dark body, body.dark-mode{background:#050508;color:#fff}
      body.light-mode{background:#fafafa;color:#050508}

      /* Loader */
      #loader{position:fixed;inset:0;z-index:9999;background:#050508;display:flex;align-items:center;justify-content:center;flex-direction:column;transition:opacity .6s,visibility .6s}
      #loader.hidden{opacity:0;visibility:hidden;pointer-events:none}
      .loader-ring{width:60px;height:60px;border:3px solid rgba(212,168,67,.15);border-top-color:#D4A843;border-radius:50%;animation:spin 1s linear infinite}
      @keyframes spin{to{transform:rotate(360deg)}}

      /* Custom Cursor */
      .cursor-dot{width:8px;height:8px;background:#D4A843;border-radius:50%;position:fixed;pointer-events:none;z-index:10000;transition:transform .15s;mix-blend-mode:difference}
      .cursor-ring{width:40px;height:40px;border:1.5px solid rgba(212,168,67,.5);border-radius:50%;position:fixed;pointer-events:none;z-index:10000;transition:transform .3s,width .3s,height .3s,border-color .3s;transform:translate(-50%,-50%)}
      .cursor-ring.hover{width:60px;height:60px;border-color:#D4A843;background:rgba(212,168,67,.08)}
      @media(max-width:768px){.cursor-dot,.cursor-ring{display:none}body{cursor:auto}}

      /* Aurora & Backgrounds */
      .dark .aurora-bg{position:absolute;inset:0;overflow:hidden;z-index:0}
      .dark .aurora-bg::before{content:'';position:absolute;width:200%;height:200%;top:-50%;left:-50%;background:radial-gradient(circle at 30% 50%, rgba(212,168,67,0.08) 0%, transparent 50%), radial-gradient(circle at 70% 30%, rgba(139,105,20,0.05) 0%, transparent 50%);animation:aurora 15s ease-in-out infinite alternate}
      @keyframes aurora{0%{transform:translate(0,0) rotate(0deg)}100%{transform:translate(50px,50px) rotate(10deg)}}
      .light-mode .aurora-bg{display:none}

      /* Shooting Stars */
      .shooting-star{position:absolute;width:100px;height:1px;background:linear-gradient(90deg, rgba(212,168,67,0.8), transparent);opacity:0;animation:shoot 3s linear infinite}
      .shooting-star:nth-child(1){top:20%;left:20%;animation-delay:0s}
      .shooting-star:nth-child(2){top:40%;left:60%;animation-delay:2s}
      .shooting-star:nth-child(3){top:60%;left:40%;animation-delay:4s}
      @keyframes shoot{0%{transform:translateX(0) translateY(0) rotate(-45deg);opacity:1}100%{transform:translateX(500px) translateY(500px) rotate(-45deg);opacity:0}}

      /* Glassmorphism */
      .dark .glass{background:rgba(255,255,255,.03);backdrop-filter:blur(20px);border:1px solid rgba(212,168,67,.1)}
      .light-mode .glass{background:rgba(255,255,255,.7);backdrop-filter:blur(20px);border:1px solid rgba(212,168,67,.2);box-shadow:0 4px 20px rgba(0,0,0,0.05)}

      /* Gradient Text */
      .gold-text{background:linear-gradient(135deg,#F0D78C,#D4A843,#8B6914,#D4A843,#F0D78C);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:goldShimmer 4s linear infinite}
      @keyframes goldShimmer{0%{background-position:0% center}100%{background-position:200% center}}

      /* Glow Button */
      .glow-btn{position:relative;overflow:hidden;transition:all .4s}
      .glow-btn::after{content:'';position:absolute;top:50%;left:50%;width:0;height:0;background:rgba(255,255,255,.15);border-radius:50%;transform:translate(-50%,-50%);transition:width .6s,height .6s}
      .glow-btn:active::after{width:300px;height:300px}
      .dark .glow-btn:hover{box-shadow:0 0 25px rgba(212,168,67,.4)}

      /* Card Shine & Tilt */
      .card-shine{position:relative;overflow:hidden}
      .card-shine::after{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:linear-gradient(135deg,transparent 40%,rgba(212,168,67,.05) 50%,transparent 60%);transform:rotate(45deg) translateY(100%);transition:transform .8s}
      .card-shine:hover::after{transform:rotate(45deg) translateY(-100%)}
      .tilt-card{transition:transform .4s,box-shadow .4s;transform-style:preserve-3d}

      /* Progress Bars */
      .skill-bar{height:6px;border-radius:3px;overflow:hidden}
      .dark .skill-bar{background:rgba(255,255,255,.06)}
      .light-mode .skill-bar{background:rgba(0,0,0,.06)}
      .skill-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#8B6914,#D4A843,#FFD700);width:0;transition:width 1.5s cubic-bezier(.4,0,.2,1)}

      /* Circular Progress */
      .circle-progress{transform:rotate(-90deg)}
      .circle-bg{fill:none;stroke-width:4}
      .dark .circle-bg{stroke:rgba(255,255,255,.06)}
      .light-mode .circle-bg{stroke:rgba(0,0,0,.06)}
      .circle-fill{fill:none;stroke-width:4;stroke:#D4A843;stroke-linecap:round;transition:stroke-dashoffset 1.5s cubic-bezier(.4,0,.2,1)}

      /* Timeline */
      .timeline-line{position:absolute;left:20px;top:0;bottom:0;width:2px}
      .dark .timeline-line{background:linear-gradient(to bottom,rgba(212,168,67,.3),rgba(212,168,67,.05))}
      .light-mode .timeline-line{background:linear-gradient(to bottom,rgba(212,168,67,.5),rgba(212,168,67,.1))}
      .timeline-dot{width:14px;height:14px;border-radius:50%;background:#D4A843;border:3px solid var(--bg-color);position:absolute;left:14px;top:6px;z-index:2;box-shadow:0 0 12px rgba(212,168,67,.4)}
      @media(min-width:768px){.timeline-line{left:50%;transform:translateX(-50%)}.timeline-dot{left:50%;transform:translateX(-50%)}}

      /* Masonry Gallery */
      .masonry-grid{columns:1;gap:16px}
      @media(min-width:640px){.masonry-grid{columns:2}}
      @media(min-width:1024px){.masonry-grid{columns:3}}
      .masonry-item{break-inside:avoid;margin-bottom:16px;position:relative;overflow:hidden;border-radius:16px;cursor:pointer}
      .masonry-item img{width:100%;display:block;transition:transform .5s}
      .masonry-item:hover img{transform:scale(1.05)}

      /* Lightbox */
      #lightbox{position:fixed;inset:0;z-index:9998;background:rgba(0,0,0,.95);display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;transition:all .3s;cursor:auto}
      #lightbox.active{opacity:1;visibility:visible}
      #lightbox img{max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px}

      /* Typing */
      .typing-cursor{display:inline-block;width:3px;height:1em;background:#D4A843;margin-left:4px;animation:blink 1s step-end infinite;vertical-align:text-bottom}
      @keyframes blink{50%{opacity:0}}

      /* Floating & Blobs */
      .float{animation:float 6s ease-in-out infinite}
      .float-delay{animation:float 6s ease-in-out 2s infinite}
      @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-20px)}}
      .blob{position:absolute;border-radius:50%;filter:blur(80px);opacity:.12;animation:blobMove 10s ease-in-out infinite alternate}
      @keyframes blobMove{0%{transform:translate(0,0) scale(1)}50%{transform:translate(30px,-30px) scale(1.1)}100%{transform:translate(-20px,20px) scale(.95)}}

      /* Marquee */
      .marquee{display:flex;overflow:hidden;white-space:nowrap}
      .marquee-inner{display:flex;animation:marquee 30s linear infinite}
      @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

      /* Theme Toggle */
      .theme-toggle{position:relative;width:50px;height:26px;border-radius:13px;cursor:pointer;transition:background .3s}
      .dark .theme-toggle{background:rgba(255,255,255,.1)}
      .light-mode .theme-toggle{background:rgba(0,0,0,.1)}
      .theme-toggle::after{content:'';position:absolute;width:20px;height:20px;border-radius:50%;top:3px;left:3px;background:#D4A843;transition:transform .3s}
      .light-mode .theme-toggle::after{transform:translateX(24px)}

      /* Photo glow */
      .photo-glow{position:relative}
      .photo-glow::before{content:'';position:absolute;inset:-4px;border-radius:50%;background:conic-gradient(from 0deg,#D4A843,#FFD700,#8B6914,#D4A843);animation:spin 3s linear infinite;z-index:0}
      .photo-glow::after{content:'';position:absolute;inset:-20px;border-radius:50%;background:radial-gradient(circle,rgba(212,168,67,.2),transparent 70%);z-index:-1}

      /* Scroll Progress */
      #scrollProgress{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,#8B6914,#D4A843,#FFD700);z-index:9990;transition:width .1s}

      /* Magnetic Button */
      .magnetic-btn{transition:transform .3s ease-out}

      /* Skeleton */
      .skeleton{background:linear-gradient(90deg,rgba(128,128,128,0.1) 25%,rgba(128,128,128,0.2) 50%,rgba(128,128,128,0.1) 75%);background-size:200% 100%;animation:skeleton-shimmer 1.5s infinite}
      @keyframes skeleton-shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

      /* Filter active */
      .tab-btn.active{color:#D4A843;border-color:#D4A843;background:rgba(212,168,67,.08)}
    </style>
</head>
